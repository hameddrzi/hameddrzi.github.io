---
import { profile } from '../data/cv';

const items = [
  { href: '#about', label: 'About' },
  { href: '#experience', label: 'Experience' },
  { href: '#projects', label: 'Projects' },
  { href: '#skills', label: 'Skills' },
  { href: '#contact', label: 'Contact' },
];
---

<nav class="nav">
  <a href="#top" class="nav-brand" aria-label="Home">
    <span class="dot"></span>
    <span class="nav-name">{profile.firstName}<b>.</b>{profile.lastName.slice(0,3)}</span>
  </a>

  <ul class="nav-links">
    {items.map((it, i) => (
      <li><a href={it.href} data-idx={i}><span class="idx">0{i+1}</span> {it.label}</a></li>
    ))}
  </ul>

  <a href={profile.cvPdf} target="_blank" class="nav-cta">
    CV <span class="arrow">→</span>
  </a>
</nav>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 18px 28px;
    background: rgba(8, 8, 12, 0.55);
    backdrop-filter: blur(18px) saturate(1.2);
    -webkit-backdrop-filter: blur(18px) saturate(1.2);
    border-bottom: 1px solid var(--line);
  }

  .nav-brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    letter-spacing: -0.02em;
    font-size: 0.95rem;
    transition: opacity 0.3s;
  }

  .nav-brand:hover { opacity: 0.8; }

  .nav-brand .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--grad);
    box-shadow: 0 0 0 3px rgba(15, 191, 250, 0.12), 0 0 24px rgba(177, 105, 219, 0.6);
    animation: pulse 2.4s ease-in-out infinite;
  }

  .nav-brand b {
    color: var(--grad-1);
    font-weight: 700;
  }

  @keyframes pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.15); }
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 4px;
  }

  .nav-links a {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    padding: 8px 14px;
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--muted);
    transition: color 0.3s, background 0.3s;
  }

  .nav-links a:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.06);
  }

  .idx {
    font-family: 'Source Code Pro', monospace;
    font-size: 0.6rem;
    opacity: 0.5;
    letter-spacing: 0.1em;
  }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 9px 16px;
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    background: #fff;
    color: #111;
    transition: transform 0.3s var(--ease-pop), box-shadow 0.3s;
  }

  .nav-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(255, 255, 255, 0.15);
  }

  .nav-cta .arrow {
    transition: transform 0.3s var(--ease);
  }

  .nav-cta:hover .arrow {
    transform: translateX(4px) rotate(-45deg);
  }

  @media (max-width: 820px) {
    .nav-links { display: none; }
    .nav { padding: 14px 18px; }
  }
</style>
