---
// Custom follower cursor — inspired by UI1.
---

<div class="cursor" id="cursor" aria-hidden="true">
  <span class="cursor-dot"></span>
</div>

<style>
  .cursor {
    position: fixed;
    top: 0;
    left: 0;
    width: 38px;
    height: 38px;
    margin: -19px 0 0 -19px;
    border-radius: 50%;
    border: 1.5px solid rgba(255, 255, 255, 0.35);
    pointer-events: none;
    z-index: 9999;
    transition:
      width 0.3s var(--ease),
      height 0.3s var(--ease),
      margin 0.3s var(--ease),
      border-color 0.3s,
      background 0.3s,
      transform 0.12s ease-out;
    mix-blend-mode: difference;
    will-change: transform;
  }

  .cursor-dot {
    position: absolute;
    inset: 0;
    margin: auto;
    width: 4px;
    height: 4px;
    background: #fff;
    border-radius: 50%;
    transition: opacity 0.25s;
  }

  .cursor.hover {
    width: 64px;
    height: 64px;
    margin: -32px 0 0 -32px;
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .cursor.hover .cursor-dot { opacity: 0; }

  .cursor.link {
    width: 80px;
    height: 80px;
    margin: -40px 0 0 -40px;
    background: rgba(255, 255, 255, 0.9);
    border-color: transparent;
    mix-blend-mode: normal;
  }

  .cursor.link .cursor-dot { opacity: 0; }

  @media (hover: none) {
    .cursor { display: none; }
  }
</style>

<script>
  const el = document.getElementById('cursor');
  if (el && window.matchMedia('(hover: hover)').matches) {
    let tx = window.innerWidth / 2;
    let ty = window.innerHeight / 2;
    let cx = tx;
    let cy = ty;

    window.addEventListener('pointermove', (e) => {
      tx = e.clientX;
      ty = e.clientY;
    });

    const step = () => {
      cx += (tx - cx) * 0.22;
      cy += (ty - cy) * 0.22;
      el.style.transform = `translate(${cx}px, ${cy}px)`;
      requestAnimationFrame(step);
    };
    step();

    const setHover = (on: boolean, kind: 'hover' | 'link' = 'hover') => {
      el.classList.remove('hover', 'link');
      if (on) el.classList.add(kind);
    };

    document.addEventListener('mouseover', (e) => {
      const t = e.target as HTMLElement;
      if (!t) return;
      if (t.closest('a, button, .chip, [data-cursor="link"]')) {
        setHover(true, 'link');
      } else if (t.closest('[data-cursor="hover"]')) {
        setHover(true, 'hover');
      }
    });

    document.addEventListener('mouseout', (e) => {
      const t = e.target as HTMLElement;
      if (!t) return;
      if (t.closest('a, button, .chip, [data-cursor]')) {
        setHover(false);
      }
    });
  } else if (el) {
    el.style.display = 'none';
    document.body.classList.remove('cursor-hidden');
  }
</script>
