---
import '../styles/global.css';
import { profile } from '../data/cv';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${profile.name} — ${profile.role}`,
  description = profile.tagline,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="theme-color" content="#08080c" />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Cdefs%3E%3ClinearGradient id='g' x1='0' y1='0' x2='1' y2='1'%3E%3Cstop offset='0%25' stop-color='%23b169db'/%3E%3Cstop offset='50%25' stop-color='%23f7d152'/%3E%3Cstop offset='100%25' stop-color='%230fbffa'/%3E%3C/linearGradient%3E%3C/defs%3E%3Ccircle cx='16' cy='16' r='13' fill='url(%23g)'/%3E%3Ctext x='16' y='21' text-anchor='middle' font-family='Inter,sans-serif' font-size='14' font-weight='900' fill='%23111'%3EH%3C/text%3E%3C/svg%3E" />

  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
</head>
<body class="cursor-hidden">
  <slot />

  <script>
    // reveal-on-scroll
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          e.target.classList.add('in');
          io.unobserve(e.target);
        }
      }
    }, { threshold: 0.15, rootMargin: '0px 0px -80px 0px' });

    const observe = () => document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', observe);
    } else {
      observe();
    }
  </script>
</body>
</html>
